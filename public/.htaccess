RewriteEngine On

# ======================================================
# 1️⃣ FORCE HTTPS
# ======================================================
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ======================================================
# 2️⃣ FORCE WWW (REMOVE if you prefer non-www)
# ======================================================
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ======================================================
# 3️⃣ REMOVE TRAILING SLASH (except folders)
# example.com/about/ → example.com/about
# ======================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ======================================================
# 4️⃣ REDIRECT index.html → / & /index → /
# ======================================================
RewriteRule ^index/?$ / [R=301,L]
RewriteCond %{THE_REQUEST} \s/+index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ======================================================
# 5️⃣ REMOVE .html EXTENSION
# example.com/about.html → example.com/about
# ======================================================
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# ======================================================
# 6️⃣ INTERNAL REWRITE TO .html
# example.com/about → about.html
# ======================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ======================================================
# 7️⃣ CUSTOM 404 PAGE (Astro)
# ======================================================
ErrorDocument 404 /404.html

