---
import { getImage } from 'astro:assets';
import '@fontsource-variable/phudu';
import '@fontsource-variable/inter';
import interFont from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import phuduFont from '@fontsource-variable/phudu/files/phudu-latin-wght-normal.woff2?url';
import "../styles/global.css";
import "../styles/datetime-picker.css";
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import HeroImage from '../assets/banners/hero.jpg';
import Logo from '../assets/logo/logo.png';
import { withBase } from '../utils/url';

const { title, description, image } = Astro.props;
const metaTitle = title;
const siteUrl = "https://jdktransportation.com";
const metaUrl = `${siteUrl}${Astro.url.pathname}`;

const ogImage = await getImage({ src: image ?? HeroImage, width: 1200, format: 'jpg' });
const ogImageUrl = `${siteUrl}${ogImage.src}`;

const logoImage = await getImage({ src: Logo, format: 'png' });
const logoUrl = `${siteUrl}${logoImage.src}`;

const businessSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"@id": `${siteUrl}/#organization`,
	name: "JDK Transportation",
	image: logoUrl,
	url: siteUrl,
	telephone: "+1-877-377-7172",
	email: "info@jdktransportation.com",
	priceRange: "$$",
	address: {
		"@type": "PostalAddress",
		streetAddress: "400 Rella Blvd #207-4",
		addressLocality: "Montebello",
		addressRegion: "NY",
		postalCode: "10901",
		addressCountry: "US",
	},
	areaServed: [
		"Newark, NJ", "Jersey City, NJ", "New York, NY", "Philadelphia, PA",
		"Toronto, ON", "Niagara Falls, NY", "Niagara Falls, ON", "Miami, FL",
		"Fort Lauderdale, FL", "Orlando, FL", "Daytona Beach, FL",
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin>
		<link rel="preload" href={phuduFont} as="font" type="font/woff2" crossorigin>
		<link rel="icon" type="image/png" href={withBase('/favicon-96x96.png')} sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="shortcut icon" href={withBase('/favicon.ico')} />
		<link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
		<link rel="manifest" href={withBase('/site.webmanifest')} />
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={metaUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="JDK Transportation" />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={metaUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={metaTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

		<ClientRouter />
	</head>
	<body>
		<Header />

		<main>
			<slot />
		</main>

		<Footer />

		<script>
			import "../scripts/datetimepicker.js";
		</script>

		<!-- Google Places Autocomplete Initialization -->
		<script is:inline>
			function initPlacesAutocomplete() {
				var fields = document.querySelectorAll('.places-autocomplete');
				var options = {
					types: ['geocode'],
					componentRestrictions: { country: ['us', 'ca'] }
				};
				fields.forEach(function(input) {
					var ac = new google.maps.places.Autocomplete(input, options);
					ac.addListener('place_changed', function() {
						var place = ac.getPlace();
						if (place && place.formatted_address) {
							input.value = place.formatted_address;
						}
					});
				});
			}

			// Re-initialize after every View Transition navigation
			document.addEventListener('astro:page-load', function() {
				if (window.google && window.google.maps && window.google.maps.places) {
					initPlacesAutocomplete();
				}
			});
		</script>
		<script is:inline async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCSfZbNztBBdV-KdtuM4RmMtjvIm4q9F4c&loading=async&libraries=places&callback=initPlacesAutocomplete"></script>
	</body>
</html>
