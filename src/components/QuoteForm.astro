---
---


<section class="bg-gray-100 py-12">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-8">
      <h2 class="text-4xl md:text-5xl font-extrabold uppercase font-phudu tracking-wide">
        REQUEST A INSTANT 
        <span class="text-primary">QUOTE</span>
      </h2>
    </div>

    <!-- Form -->
    <form class="grid md:grid-cols-4 gap-x-12 gap-y-6" id="quoteForm" novalidate>

      <!-- Row 1 -->
      <div class="relative">
        <input type="text" placeholder="Group Name" name="gname" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="gnameError"></small>
      </div>

      <div class="relative">
        <input type="text" placeholder="Full Name" name="fname" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="fnameError"></small>
      </div>

      <div class="relative">
        <input type="email" placeholder="Email Address" name="email" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="emailError"></small>
      </div>

      <div class="relative">
        <input type="tel" placeholder="Phone Number" name="phone" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300" oninput="this.value=this.value.replace(/[^0-9+ -]/g,'')">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="phoneError"></small>
      </div>

      <div class="relative">
        <input type="text" placeholder="Tour Type" name="tourtype" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="tourtypeError"></small>
      </div>

      <div class="relative">
        <input type="text" placeholder="Tour Destination" name="tourdesti" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="tourdestiError"></small>
      </div>

      <div class="relative">
        <input type="text" placeholder="Tour Date & Time" name="datetime" class="minimal-picker font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300" readonly inputmode="none">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="datetimeError"></small>
      </div>

      <div class="relative">
        <input type="text" placeholder="Pickup Location" name="pickuploc" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="pickuplocError"></small>
      </div>

      <!-- Row 3 -->
      <div class="relative">
        <input type="number" placeholder="No. Of Guests in Groups" name="noofpass" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="noofpassError"></small>
      </div>

      <!-- Additional Info (Span 2 Columns) -->
      <div class="md:col-span-2 relative">
        <input type="text" placeholder="Additional Info" name="addinfo" class="font-light w-full bg-transparent border-b border-gray-400 focus:outline-none py-2 placeholder-gray-700 transition duration-300">
        <small class="error text-red-500 text-xs absolute top-full left-0" id="addinfoError"></small>
      </div>

      <!-- Honeypot -->
      <div class="hidden">
        <input type="text" name="website">
      </div>

      <!-- Request Button -->
      <div class="flex items-end">
        <button type="submit" id="submitBtn"
          class="font-normal w-full h-full py-2.25 md:py-0 rounded-full bg-primary hover:bg-yellow-600 text-black uppercase transition duration-300 cursor-pointer">
          Request
        </button>
      </div>

    </form>

  </div>
</section>

<style>
    /* Hide the spin buttons in WebKit browsers */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Hide spin buttons in Firefox */
    input[type="number"] {
        -moz-appearance: textfield;
    }
</style>

<script>

const form = document.getElementById("quoteForm");
const btn = document.getElementById("submitBtn");

form.addEventListener("submit", async function (e) {
  e.preventDefault();

  let isValid = true;
  const fields = ["gname","fname","email","phone","tourtype","tourdesti","datetime","pickuploc","noofpass","addinfo"];

  document.querySelectorAll(".error").forEach(el => el.textContent = "");

  fields.forEach(name => {
    const input = form.querySelector(`[name="${name}"]`);
    if (!input.value.trim()) {
      document.getElementById(name+"Error").textContent = "Required";
      input.classList.add("border-red-500");
      isValid = false;
    }
  });

  // Email validation
  if (!/^\S+@\S+\.\S+$/.test(form.email.value)) {
    document.getElementById("emailError").textContent = "Invalid email";
    isValid = false;
  }

  // Phone validation
  const phoneValue = form.phone.value.trim();
  const cleanedPhone = phoneValue.replace(/\D/g, "");

  if (cleanedPhone.length < 10 || cleanedPhone.length > 15) {
    document.getElementById("phoneError").textContent = "Invalid phone number";
    isValid = false;
  }

  if (!isValid) return;

  btn.innerText = "Sending...";
  btn.disabled = true;

  const res = await fetch("/quoteform.php", {
    method: "POST",
    body: new FormData(form)
  });

  const data = await res.json();

  if (data.status === "success") {

    // ✅ Clear all fields
    form.reset();

    // Optional: clear error messages
    document.querySelectorAll(".error").forEach(el => el.textContent = "");

    // Small delay (optional)
    setTimeout(() => {
      window.location.href = "/success";
    }, 500);

  } else {
    alert(data.message || "Something went wrong");
    btn.innerText = "Request";
    btn.disabled = false;
  }
});


// ✅ Real-time validation (show + hide error dynamically)
const fields = ["gname","fname","email","phone","tourtype","tourdesti","datetime","pickuploc","noofpass","addinfo"];

fields.forEach(name => {
  const input = form.querySelector(`[name="${name}"]`);
  const errorEl = document.getElementById(name + "Error");

  input.addEventListener("input", function () {

    const value = input.value.trim();

    // Required validation
    if (value === "") {
      errorEl.textContent = "Required";
      input.classList.add("border-red-500");
      return;
    }

    // Email validation
    if (name === "email") {
      if (!/^\S+@\S+\.\S+$/.test(value)) {
        errorEl.textContent = "Invalid email";
        input.classList.add("border-red-500");
        return;
      }
    }

    // Phone validation
    if (name === "phone") {
      const cleaned = value.replace(/\D/g, "");
      if (cleaned.length < 10 || cleaned.length > 15) {
        errorEl.textContent = "Invalid phone number";
        input.classList.add("border-red-500");
        return;
      }
    }

    // If everything valid
    errorEl.textContent = "";
    input.classList.remove("border-red-500");

    });
  });
</script>