---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const services = (await getCollection('services'))
  .filter((service) => service.id !== currentSlug)
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="bg-gray-100 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="text-center mb-8">
      <h2 class="text-4xl md:text-5xl font-phudu font-extrabold uppercase tracking-wide">
        <slot name="heading">
          MOTOR COACH SERVICES WE OFFER IN
          <span class="text-primary">JDK</span>
        </slot>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      {services.map((service) => (
        <div class="group bg-white rounded-2xl overflow-hidden shadow-md transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">

          <div class="overflow-hidden">
            <Image src={service.data.heroImage} alt={service.data.title} quality={1} class="w-full h-48 object-cover transition-transform duration-700 group-hover:scale-110" />
          </div>

          <div class="p-6">
            <h3 class="font-medium text-lg mb-2 leading-6">
              {service.data.title}
            </h3>

            <p class="text-sm leading-snug font-light line-clamp-3">
              {service.data.summary}
            </p>

            <a href={`/services/${service.id}`} class="group/link inline-flex items-center gap-1 mt-2 text-sm font-semibold text-primary">
              View More <span class="inline-block transition-transform duration-300 group-hover/link:translate-x-1">&rarr;</span>
            </a>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>
