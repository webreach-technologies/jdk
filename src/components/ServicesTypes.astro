        <!-- Image Wrapper -->
        <div class="overflow-hidden">
            <Image src={Bus7} alt="Travel Agent Bus Rentals " quality={5} class="w-full h-48 object-cover transition-transform duration-700 group-hover:scale-110"></Image>
        </div>

        <!-- Content -->
        <div class="p-6">
            <h3 class="font-medium text-lg mb-2 leading-6">
            Travel Agent Bus Rentals
            </h3>

