---
import { Image } from 'astro:assets';
import Cta from "../assets/banners/cta.jpg";
---


<section class="relative w-full py-12 md:py-24 text-white">

  <!-- Background Image -->
  <div class="absolute inset-0">
    <Image src={Cta} alt="Book charter bus" quality={5} class="w-full h-full object-cover"></Image>
    <div class="absolute inset-0 bg-primary/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Heading -->
    <h2 class="text-4xl md:text-5xl font-phudu font-extrabold uppercase tracking-wide">
      Call 24/7 to book your Charter Bus Rental!
    </h2>

    <div class="mt-10 flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6">

      <a href="tel:+13864447344" class="flex items-center gap-2 shrink-0 bg-white text-black px-4 py-3 text-sm rounded-full hover:scale-105 transition duration-300">
