        <p class="text-sm font-normal leading-snug">
          PA System / Microphones
        </p>
      </div>

      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities12} alt="Panoramic Windows" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
        </div>
        <p class="text-sm font-normal leading-snug">
          Panoramic Windows
        </p>
      </div>

      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities13} alt="Interior and Ambient Lighting" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
        </div>
        <p class="text-sm font-normal leading-snug">
          Interior and Ambient Lighting
        </p>
      </div>
      
      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities6} alt="Climate Control with Personal Air Vents" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
        </div>
        <p class="text-sm font-normal leading-snug">
          Climate Control with Personal Air Vents
        </p>
      </div>

      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities14} alt="Perimeter Lighting for Night Visibility" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
        </div>
        <p class="text-sm font-normal leading-snug">
          Perimeter Lighting for Night Visibility
        </p>
      </div>

      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities15} alt="Entry Stairway for Smooth Boarding" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
