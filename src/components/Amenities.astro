          <!-- Icon -->
          <Image src={Amenities10} alt="Onboard Entertainment System (TVs, DVD/Blu-ray, Streaming)" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
        </div>
        <p class="text-sm font-normal leading-snug">
          Onboard Entertainment System (TVs, DVD/Blu-ray, Streaming)
        </p>
