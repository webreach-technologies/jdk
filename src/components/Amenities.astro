        <p class="text-sm font-normal leading-snug">
          Entry Stairway for Smooth Boarding
        </p>
      </div>

      <div class="bg-white border border-gray-400 rounded-2xl py-8 md:py-6 px-6 text-center transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl cursor-pointer">
        <div class="mb-3 flex justify-center">
          <!-- Icon -->
          <Image src={Amenities16} alt="Standard, Premium, Luxury Seating" class="w-14 md:w-12 h-14 md:h-12 object-contain"></Image>
