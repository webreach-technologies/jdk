---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import CalltoBook from '../components/CalltoBook.astro';
import QuoteModalForm from '../components/QuoteModalForm.astro';
import ContactHero from "../assets/banners/cta.jpg";

const siteUrl = "https://jdktransportation.com";

const locations = [
  { name: "New York", address: "400 Rella Blvd #207-4, Montebello, NY, 10901, United States" },
  { name: "Orlando", address: "13329 Greenpoint Dr, Orlando, FL 32824, United States" },
  { name: "Miami (South Florida)", address: "13810 SW 284th Street Homestead, FL 33033, United States" },
  { name: "Daytona Beach", address: "211 E International Speedway Blvd, Daytona Beach, FL 32118, United States" },
];

const faqs = [
  {
    question: "What is the fastest way to get a quote?",
    answer: "Fill out the form on this page or our online quote form, and our team will respond with a custom quote in as little as 30 minutes. You can also call us directly at 877-377-7172."
  },
  {
    question: "Is someone available if I need help outside business hours?",
    answer: "Yes. Our dispatch and support team is available 24/7. For urgent or same-day needs, call our Emergency Dispatch line at 888-487-7507."
  },
  {
    question: "What information should I include when I contact you?",
    answer: "Let us know your pickup and destination locations, travel date and time, group size, and the type of trip. The more details you provide, the faster we can put together an accurate quote."
  },
  {
    question: "Do you serve locations outside of your listed offices?",
    answer: "Our offices are located in New York, Orlando, Miami, and Daytona Beach, but our motor coach services extend across many metro areas. Contact us to confirm availability for your route."
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl + "/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Contact Us",
          "item": siteUrl + "/contact"
        }
      ]
    },
    {
      "@type": "ContactPage",
      "name": "Contact JDK Transportation",
      "url": siteUrl + "/contact",
      "description": "Get in touch with JDK Transportation for motor coach rental quotes, bookings, and support. Call, email, or send us a message online.",
      "mainEntity": {
        "@type": "Organization",
        "name": "JDK Transportation",
        "url": siteUrl,
        "telephone": "+1-877-377-7172",
        "email": "info@jdktransportation.com",
        "address": locations.map((location) => ({
          "@type": "PostalAddress",
          "name": location.name,
          "streetAddress": location.address
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};
---

<Layout
  title="Contact Us | JDK Transportation - Motor Coach Rental Company"
  description="Contact JDK Transportation for motor coach rental quotes, bookings, and 24/7 support. Call 877-377-7172, email us, or send a message online.">

  <!-- Contact Hero -->
  <section aria-labelledby="contact-hero-heading" class="relative w-full py-28 md:py-40 text-center text-white">

    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image src={ContactHero} alt="" quality={40} loading="eager" fetchpriority="high" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-4 text-sm font-light">
        <ol class="flex items-center justify-center gap-2">
          <li><a href="/" class="hover:text-primary transition duration-300">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-primary">Contact Us</li>
        </ol>
      </nav>

      <h1 id="contact-hero-heading" class="text-4xl md:text-6xl font-phudu font-extrabold uppercase tracking-wide">
        Contact Us
      </h1>

      <p class="mt-4 text-base md:text-lg font-light leading-snug">
        Questions, quotes, or booking changes &mdash; our team is here to help, 24 hours a day.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="javascript:void(0)" class="open-modal flex items-center gap-2 bg-primary text-black font-normal px-6 py-3 text-sm rounded-full transition-all duration-300 hover:scale-105">
          Get a Quote in 30 Minutes
        </a>
        <a href="tel:+18773777172" class="flex items-center gap-2 bg-white text-black font-normal px-6 py-3 text-sm rounded-full transition-all duration-300 hover:scale-105">
          Call: 877-377-7172
        </a>
      </div>

    </div>
  </section>

  <!-- Get In Touch -->
  <section aria-labelledby="contact-info-heading" class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-10">

      <!-- Contact Details -->
      <div>
        <h2 id="contact-info-heading" class="text-center md:text-start text-4xl md:text-5xl font-phudu font-extrabold uppercase tracking-wide">
          Get In <span class="text-primary">Touch</span>
        </h2>

        <p class="mt-5 text-base md:text-lg font-light leading-snug">
          Whether you need a quote for an upcoming trip, want to make changes to an existing
          booking, or just have a question about our services, our team is ready to help.
          Reach out using the details below or send us a message and we'll get back to you shortly.
        </p>

        <div class="mt-8 space-y-5 text-sm md:text-base font-light">

          <p class="flex items-center gap-3">
            <span class="shrink-0" aria-hidden="true"><svg id='Phone_24' width='23' height='23' viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink'><rect width='24' height='24' stroke='none' fill='#000000' opacity='0'/>
