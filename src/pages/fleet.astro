---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BusesTypes from '../components/BusesTypes.astro';
import Amenities from '../components/Amenities.astro';
import FAQ from '../components/FAQ.astro';
import CalltoBook from '../components/CalltoBook.astro';
import QuoteModalForm from '../components/QuoteModalForm.astro';
import FleetHero from "../assets/banners/wcu.jpg";
import { withBase } from '../utils/url';

const siteUrl = "https://jdktransportation.com";

const vehicles = (await getCollection('fleet')).sort((a, b) => a.data.order - b.data.order);

const faqs = [
  {
    question: "What types of vehicles are in JDK Transportation's fleet?",
    answer: "Our fleet includes 50 to 56 passenger motor coaches, 30 to 40 passenger mini coaches, 15 to 28 passenger mini buses, sprinter vans, and party buses, giving groups of every size a comfortable, well-maintained option for any trip."
  },
  {
    question: "How many passengers can your buses hold?",
    answer: "Vehicle capacities range from 15 passengers in our smallest mini buses up to 56 passengers in our largest motorcoaches, so you can match the vehicle to your exact group size."
  },
  {
    question: "Are your vehicles equipped with Wi-Fi and other amenities?",
    answer: "Many vehicles in our fleet include amenities such as reclining seats, climate control, power outlets and USB charging, panoramic windows, and onboard entertainment. Availability varies by vehicle, so let us know what matters most for your trip."
  },
  {
    question: "How do I choose the right vehicle size for my group?",
    answer: "Our 24/7 dispatch team can help you select the right bus based on your headcount, luggage needs, and itinerary. Call us or request a quote and we'll recommend the best fit for your group."
  },
  {
    question: "Are your drivers licensed, trained, and insured?",
    answer: "Yes. Every driver is licensed, trained, and background-checked, and every vehicle in our fleet is regularly inspected and fully insured for your group's safety."
  },
  {
    question: "How far in advance should I book a vehicle?",
    answer: "We recommend booking as early as possible, especially during peak seasons such as proms, holidays, and summer travel, though our team works hard to accommodate last-minute requests too."
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl + "/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Our Fleet",
          "item": siteUrl + "/fleet"
        }
      ]
    },
    {
      "@type": "Service",
      "serviceType": "Motor Coach Rental",
      "name": "JDK Transportation Fleet",
      "description": "A diverse fleet of motor coaches, mini buses, sprinter vans, and party buses available for rental, seating 15 to 56 passengers.",
      "provider": {
        "@type": "Organization",
        "name": "JDK Transportation",
        "url": siteUrl,
        "telephone": "+1-877-377-7172",
        "email": "info@jdktransportation.com"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Motor Coach Fleet",
        "itemListElement": vehicles.map((vehicle, index) => ({
          "@type": "Offer",
          "position": index + 1,
          "itemOffered": {
            "@type": "Product",
            "name": vehicle.data.title,
            "description": vehicle.data.capacity,
            "url": siteUrl + "/fleet/" + vehicle.id
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};
---

<Layout
  title="Our Fleet | Motor Coaches, Mini Buses & Sprinter Vans | JDK Transportation"
  description="Explore JDK Transportation's full fleet of motor coaches, mini buses, sprinter vans, and party buses. Modern, well-maintained vehicles seating 15 to 56 passengers for groups of any size.">

  <!-- Fleet Hero -->
  <section aria-labelledby="fleet-hero-heading" class="relative w-full py-28 md:py-40 text-center text-white">

    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image src={FleetHero} alt="" quality={40} loading="eager" fetchpriority="high" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-4 text-sm font-light">
        <ol class="flex items-center justify-center gap-2">
          <li><a href={withBase('/')} class="hover:text-primary transition duration-300">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-primary">Our Fleet</li>
        </ol>
      </nav>

      <h1 id="fleet-hero-heading" class="text-4xl md:text-6xl font-phudu font-extrabold uppercase tracking-wide">
        Our Fleet
      </h1>

      <p class="mt-4 text-base md:text-lg font-light leading-snug">
        Motor Coaches, mini buses, sprinter vans, and party buses &mdash; seating 15 to 56 passengers
        and ready for groups of every size.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="javascript:void(0)" class="open-modal flex items-center gap-2 bg-primary text-black font-normal px-6 py-3 text-sm rounded-full transition-all duration-300 hover:scale-105">
          Get a Quote in 30 Minutes
        </a>
        <a href="tel:+18773777172" class="flex items-center gap-2 bg-white text-black font-normal px-6 py-3 text-sm rounded-full transition-all duration-300 hover:scale-105">
          Call: 877-377-7172
        </a>
      </div>

    </div>
  </section>

  <!-- Fleet Overview -->
  <section aria-labelledby="fleet-overview-heading" class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-3xl mx-auto text-center">
        <h2 id="fleet-overview-heading" class="text-4xl md:text-5xl font-phudu font-extrabold uppercase tracking-wide">
          A Fleet Built for <span class="text-primary">Every Group</span>
        </h2>
        <p class="mt-5 text-base md:text-lg font-light leading-snug">
          From intimate sprinter vans to full-size 56-passenger motorcoaches, JDK Transportation's
          fleet is maintained to the highest safety standards and equipped with the comfort features
          groups expect. Whether you're planning a school trip, corporate event, wedding, sports
          tournament, or night out, we have the right vehicle &mdash; and a professional, licensed
          driver &mdash; ready to get your group there safely and on time.
        </p>
      </div>

      <!-- Fleet Stats -->
      <div class="mt-12 md:mt-16 bg-primary rounded-3xl px-6 py-10 md:py-12 md:px-12 shadow-lg">
        <dl class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 text-center text-black">
          <div class="flex flex-col items-center gap-2">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-black text-primary" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3ZM8 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3Zm8 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4Zm-8 0c-.29 0-.62.02-.97.05C5.81 13.4 4 14.61 4 16v2H2v-2c0-2.66 4.13-4 6-4Z" />
              </svg>
            </div>
            <dt class="text-3xl md:text-4xl font-phudu font-extrabold">15-56</dt>
            <dd class="text-sm md:text-base font-medium leading-snug">Passenger Capacity Range</dd>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-black text-primary" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 13h18M5 13V8a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v5M4 13l1 6h2l.5-2h9l.5 2h2l1-6M7 19a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm10 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" />
              </svg>
            </div>
            <dt class="text-3xl md:text-4xl font-phudu font-extrabold">13+</dt>
            <dd class="text-sm md:text-base font-medium leading-snug">Vehicle Types Available</dd>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-black text-primary" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3Zm-2.5 10.5 2 2 4-4.5" />
              </svg>
            </div>
            <dt class="text-3xl md:text-4xl font-phudu font-extrabold">100%</dt>
            <dd class="text-sm md:text-base font-medium leading-snug">Licensed &amp; Insured</dd>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-black text-primary" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0-13v4l3 2" />
              </svg>
            </div>
            <dt class="text-3xl md:text-4xl font-phudu font-extrabold">24/7</dt>
            <dd class="text-sm md:text-base font-medium leading-snug">Dispatch &amp; Support</dd>
          </div>
        </dl>
      </div>

    </div>
  </section>

  <!-- Why Our Fleet Stands Out -->
  <section aria-labelledby="fleet-why-heading" class="relative w-full py-12 text-white">

    <div class="absolute inset-0 bg-black"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="fleet-why-heading" class="text-center text-4xl md:text-5xl font-phudu font-extrabold uppercase tracking-wide">
        Why Our <span class="text-primary">Fleet</span> Stands Out
      </h2>

      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Feature 1 -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col items-center text-center gap-3 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10">
          <div class="text-primary" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 13h18M5 13V8a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v5M4 13l1 6h2l.5-2h9l.5 2h2l1-6M7 19a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm10 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium">Modern, Well-Maintained Vehicles</h3>
          <p class="text-sm font-light leading-snug">
            Every bus and van is regularly inspected and serviced to keep your trip safe and
            comfortable from start to finish.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col items-center text-center gap-3 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10">
          <div class="text-primary" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3ZM8 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3Zm8 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4Zm-8 0c-.29 0-.62.02-.97.05C5.81 13.4 4 14.61 4 16v2H2v-2c0-2.66 4.13-4 6-4Z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium">Seating for 15 to 56 Passengers</h3>
          <p class="text-sm font-light leading-snug">
            From small sprinter vans to full-size motorcoaches, we have the right capacity for
            groups large and small.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col items-center text-center gap-3 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10">
          <div class="text-primary" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3Zm-2.5 10.5 2 2 4-4.5" />
            </svg>
          </div>
          <h3 class="text-lg font-medium">Licensed, Professional Drivers</h3>
          <p class="text-sm font-light leading-snug">
            Every driver is licensed, trained, and background-checked &mdash; committed to getting
            your group there safely.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col items-center text-center gap-3 transition-all duration-500 hover:-translate-y-2 hover:bg-white/10">
          <div class="text-primary" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3v3m0 12v3M3 12h3m12 0h3M5.6 5.6l2 2m8.8-2-2 2m-8.8 8.8 2-2m8.8 2-2-2M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium">Premium Onboard Amenities</h3>
          <p class="text-sm font-light leading-snug">
            Reclining seats, climate control, power outlets, Wi-Fi, and more &mdash; built for
            long trips and short hops alike.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Types of Vehicles in Our Fleet -->
  <BusesTypes />

  <!-- Amenities Available -->
  <Amenities />

  <!-- FAQ -->
  <FAQ
    title="Fleet"
    subheading="Answers to common questions about our motor coaches, mini buses, and specialty vehicles."
    items={faqs}
    headingId="fleet-faq-heading"
  />

  <!-- Call to Action -->
  <CalltoBook />

  <QuoteModalForm />

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

</Layout>
